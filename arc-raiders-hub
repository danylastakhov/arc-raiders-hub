const selItems={offer:null,req:null};
function fuzzy(q,s){const ql=q.toLowerCase(),sl=s.toLowerCase();if(sl.startsWith(ql))return 3;if(sl.includes(ql))return 2;let i=0;for(const c of sl){if(i<ql.length&&c===ql[i])i++;}return i===ql.length?1:0;}
function handleAC(input,side){const q=input.value.trim();const acEl=document.getElementById(side+'-ac');if(!q||!allItems.length){acEl.style.display='none';return;}const results=allItems.map(item=>({item,score:fuzzy(q,getName(item.name)||item.id||'')})).filter(x=>x.score>0).sort((a,b)=>b.score-a.score).slice(0,10);if(!results.length){acEl.style.display='none';return;}acEl.innerHTML=results.map(({item})=>{const name=getName(item.name)||item.id;const rarity=item.rarity||'';const imgUrl='https://arcraiders.wiki/images/'+encodeURIComponent(name.replaceAll(' ','_'))+'.png';return`<div class="ac-item" onclick="selectItem('${side}','${name.replace(/'/g,"\\'")}','${rarity}')"><img class="ac-thumb" src="${imgUrl}" onerror="this.style.display='none'"/><span class="ac-name">${name}</span><span class="ac-rar" style="color:${rarityColor(rarity)}">${rarity.toUpperCase()}</span></div>`;}).join('');acEl.style.display='block';}
function selectItem(side,name,rarity){selItems[side]={name,rarity};document.getElementById(side+'-input').value=name;document.getElementById(side+'-ac').style.display='none';const imgUrl='https://arcraiders.wiki/images/'+encodeURIComponent(name.replaceAll(' ','_'))+'.png';document.getElementById(side+'-sel').innerHTML=`<div class="sel-chip"><img class="sel-thumb" src="${imgUrl}" onerror="this.style.display='none'"/><span style="color:${rarityColor(rarity)};font-size:10px;">${name}</span></div>`;}
