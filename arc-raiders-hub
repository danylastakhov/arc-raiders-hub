async function tryFetch(proxyFn){
  const url=proxyFn(TARGET_URL);
  const r=await fetch(url,{signal:AbortSignal.timeout(6000)});
  if(!r.ok)throw new Error('HTTP '+r.status);
  const json=await r.json();
  const data=json.data||json;
  if(!Array.isArray(data)||!data.length)throw new Error('empty');
  return data;
}

async function loadEventTimers(){
  document.getElementById('timer-sync-time').textContent='Syncing...';
  for(const proxyFn of PROXIES){
    try{
      const data=await tryFetch(proxyFn);
      allEvents=data;
      renderTimers();
      startTimerTick();
      document.getElementById('timer-api-status').innerHTML='<span class="status-dot dot-live"></span>TIMERS LIVE';
      document.getElementById('timer-sync-time').textContent='Live sync: '+new Date().toUTCString().slice(17,22)+' UTC';
      return;
    }catch(e){
      // try next proxy
    }
  }
  // all proxies failed — use embedded cache
  allEvents=CACHED_EVENTS;
  renderTimers();
  startTimerTick();
  document.getElementById('timer-api-status').innerHTML='<span class="status-dot dot-warn"></span>CACHED DATA';
  document.getElementById('timer-sync-time').textContent='Using embedded cache (schedules accurate)';
}
