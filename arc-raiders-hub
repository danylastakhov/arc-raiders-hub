// live countdown tick
let timerTickInterval=null;
const notifyArmed={};

function startTimerTick(){
  if(timerTickInterval)clearInterval(timerTickInterval);
  timerTickInterval=setInterval(()=>{
    const nowSec=utcNowSeconds();
    // update active timers
    document.querySelectorAll('[id^="ev-timer-a-"]').forEach((el,i)=>{
      const{ev,slot}=getActiveByIndex(i,'active');
      if(!ev)return;
      const newSlot=getNextSlot(ev.times,nowSec);
      if(newSlot&&newSlot.active){
        el.textContent='ENDS '+fmtSeconds(newSlot.secsUntilEnd);
        if(newSlot.secsUntilEnd<=0&&notifyArmed['a-'+i]){
          showToast('EVENT ENDED: '+ev.name+' on '+ev.map,'var(--red)');
        }
      } else {
        // event ended, re-render
        renderTimers();startTimerTick();return;
      }
    });
    // update upcoming timers
    document.querySelectorAll('[id^="ev-timer-u-"]').forEach((el,i)=>{
      const{ev,slot}=getActiveByIndex(i,'upcoming');
      if(!ev)return;
      const newSlot=getNextSlot(ev.times,nowSec);
      if(newSlot&&!newSlot.active){
        el.textContent='IN '+fmtSeconds(newSlot.secsUntilStart);
        if(newSlot.secsUntilStart<=0){
          renderTimers();startTimerTick();return;
        }
        if(newSlot.secsUntilStart<900){
          el.className='timer-display timer-soon';
        }
        if(notifyArmed['u-'+i]&&newSlot.secsUntilStart<=60){
          showToast('STARTING: '+ev.name+' on '+ev.map,'var(--gold)');
        }
      }
    });
  },1000);
}

// helpers to get event by rendered index
let _lastActive=[];let _lastUpcoming=[];
function getActiveByIndex(i,type){
  const nowSec=utcNowSeconds();
  const filtered=mapFilter==='all'?allEvents:allEvents.filter(e=>e.map===mapFilter);
  const classified=filtered.map(ev=>({ev,slot:getNextSlot(ev.times,nowSec)}));
  const list=type==='active'
    ?classified.filter(x=>x.slot&&x.slot.active)
    :classified.filter(x=>x.slot&&!x.slot.active).sort((a,b)=>a.slot.secsUntilStart-b.slot.secsUntilStart);
  return list[i]||{ev:null,slot:null};
}

function toggleNotify(el,key,label){
  notifyArmed[key]=!notifyArmed[key];
  el.classList.toggle('on',notifyArmed[key]);
  el.querySelector('.tog-txt').textContent=notifyArmed[key]?'NOTIFY ON':'NOTIFY';
  if(notifyArmed[key])showToast('NOTIFY ARMED: '+label,'var(--green)');
}

function setMapFilter(btn,map){
  mapFilter=map;
  document.querySelectorAll('.map-pill').forEach(b=>b.classList.remove('active'));
