let allItems=[];let rarFilter='all';let searchQuery='';
function rarityColor(r){if(!r)return'#888';const l=r.toLowerCase();if(l.includes('legendary'))return'var(--gold)';if(l.includes('epic'))return'#8b00ff';if(l.includes('rare'))return'#0077cc';if(l.includes('uncommon'))return'#00b050';return'#888';}
function rarityClass(r){if(!r)return'rarity-common';const l=r.toLowerCase();if(l.includes('legendary'))return'rarity-legendary';if(l.includes('epic'))return'rarity-epic';if(l.includes('rare'))return'rarity-rare';if(l.includes('uncommon'))return'rarity-uncommon';return'rarity-common';}
function getName(obj){if(!obj)return'';if(typeof obj==='string')return obj;return obj.en||obj.english||Object.values(obj)[0]||'';}
async function loadItemPage(offset){const r=await fetch('https://arcdata.mahcks.com/v1/items?full=true&limit=45&offset='+offset,{signal:AbortSignal.timeout(10000)});if(!r.ok)throw new Error('HTTP '+r.status);const d=await r.json();return Array.isArray(d)?d:(d.items||d.data||[]);}
async function loadAllItems(){
  try{
    const first=await loadItemPage(0);
    allItems=first;renderItemGrid();
    document.getElementById('item-api-status').innerHTML='<span class="status-dot dot-live"></span>ITEMS LIVE';
    let offset=45;
    while(true){const batch=await loadItemPage(offset);if(!batch.length)break;allItems=[...allItems,...batch];document.getElementById('item-count').textContent=allItems.length+' ITEMS';document.getElementById('stat-items').textContent=allItems.length;offset+=45;if(batch.length<45)break;}
  }catch(e){document.getElementById('item-loading').innerHTML='<span style="color:var(--red);">ITEMS ERROR — '+e.message+'</span>';document.getElementById('item-api-status').innerHTML='<span class="status-dot dot-dead"></span>ITEMS OFFLINE';}
}
function getFiltered(){return allItems.filter(item=>{const name=(getName(item.name)||item.id||'').toLowerCase();const rar=(item.rarity||'').toLowerCase();return(!searchQuery||name.includes(searchQuery))&&(rarFilter==='all'||rar.includes(rarFilter));});}
function itemCard(item){const name=getName(item.name)||item.id||'Unknown';const rarity=item.rarity||'';const cat=getName(item.category)||getName(item.type)||'';const imgUrl='https://arcraiders.wiki/images/'+encodeURIComponent(name.replaceAll(' ','_'))+'.png';return`<div class="item-card"><div class="item-img-wrap"><img src="${imgUrl}" onerror="this.parentElement.innerHTML='<div class=\\'item-img-placeholder\\'>IMG</div>'"/></div><div class="item-info"><div class="item-name" title="${name}">${name}</div>${rarity?`<div class="item-rarity ${rarityClass(rarity)}">${rarity.toUpperCase()}</div>`:''} ${cat?`<div class="item-category">${cat}</div>`:''}</div></div>`;}
function renderItemGrid(){document.getElementById('item-loading').style.display='none';document.getElementById('item-count').textContent=allItems.length+' ITEMS';document.getElementById('stat-items').textContent=allItems.length;const f=getFiltered();const shown=f.slice(0,60);document.getElementById('item-grid').innerHTML=shown.map(itemCard).join('');const btn=document.getElementById('load-more-btn');btn.style.display=f.length>60?'block':'none';btn.dataset.shown=60;}
function loadMoreItems(){const btn=document.getElementById('load-more-btn');const shown=parseInt(btn.dataset.shown)||60;const f=getFiltered();document.getElementById('item-grid').innerHTML+=f.slice(shown,shown+60).map(itemCard).join('');btn.dataset.shown=shown+60;if(shown+60>=f.length)btn.style.display='none';}
function filterItems(){searchQuery=document.getElementById('item-search').value.toLowerCase();renderItemGrid();}
