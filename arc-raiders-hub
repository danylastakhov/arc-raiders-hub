<script>
// ── UTILITIES ─────────────────────────
function showToast(msg,color){
  color=color||'var(--green)';
  const t=document.createElement('div');t.className='toast';
  t.style.borderColor=color;t.style.color=color;t.textContent='>> '+msg;
  document.getElementById('toasts').appendChild(t);
  setTimeout(()=>t.remove(),4000);
}
function switchTab(id){
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  const idx={timers:0,items:1,trade:2}[id];
  document.querySelectorAll('.nav-btn')[idx].classList.add('active');
}
function pad(n){return String(n).padStart(2,'0');}
function fmtSeconds(s){
  if(s<=0)return'00:00';
  const m=Math.floor(s/60),sec=s%60;
  if(m>=60){const h=Math.floor(m/60);return pad(h)+':'+pad(m%60)+':'+pad(sec);}
  return pad(m)+':'+pad(sec);
}

// ── UTC CLOCK ─────────────────────────
function utcNowSeconds(){
  const n=new Date();
  return n.getUTCHours()*3600+n.getUTCMinutes()*60+n.getUTCSeconds();
}
function updateClocks(){
  const n=new Date();
  const utcStr=pad(n.getUTCHours())+':'+pad(n.getUTCMinutes())+':'+pad(n.getUTCSeconds());
  document.getElementById('utc-clock').textContent=utcStr;
  document.getElementById('sys-time').textContent=n.toTimeString().slice(0,8)+' LOCAL';
}
setInterval(updateClocks,1000);updateClocks();

// ── EVENT TIMERS ──────────────────────
let allEvents=[];
let timerIntervals=[];
let mapFilter='all';

function timeStrToSeconds(t){
  const[h,m]=(t||'00:00').split(':').map(Number);
  return h*3600+m*60;
}

// For each event+slot, compute: is active, seconds until start, seconds until end
function classifySlot(startSec,endSec,nowSec){
  // handle midnight wrap (e.g. end 00:00 = next day)
  let adjEnd=endSec;
  if(endSec<=startSec)adjEnd=endSec+86400;
  let adjNow=nowSec;
  if(nowSec<startSec&&adjEnd>86400)adjNow=nowSec+86400;

  const active=adjNow>=startSec&&adjNow<adjEnd;
  const secsUntilStart=active?0:((startSec-nowSec+86400)%86400);
  const secsUntilEnd=active?(adjEnd-adjNow):null;
  return{active,secsUntilStart,secsUntilEnd};
}

function getNextSlot(times,nowSec){
  // find active or nearest upcoming slot
  let best=null;
  for(const t of times){
    const start=timeStrToSeconds(t.start);
    const end=timeStrToSeconds(t.end);
    const info=classifySlot(start,end,nowSec);
    if(!best||info.active||(best.secsUntilStart>info.secsUntilStart&&!best.active)){
      best={...info,start:t.start,end:t.end,startSec:start,endSec:end};
    }
  }
  return best;
}

function renderTimers(){
  const nowSec=utcNowSeconds();
  const allMaps=[...new Set(allEvents.map(e=>e.map))].sort();

  // rebuild map filter pills if needed
  const bar=document.getElementById('map-filter-bar');
  if(bar.children.length===1){
    allMaps.forEach(map=>{
      const btn=document.createElement('button');
      btn.className='map-pill';btn.dataset.map=map;
      btn.textContent=map.toUpperCase();
      btn.onclick=function(){setMapFilter(this,map);};
      bar.appendChild(btn);
    });
  }

  const filtered=mapFilter==='all'?allEvents:allEvents.filter(e=>e.map===mapFilter);

  // classify each event by its best slot
  const classified=filtered.map(ev=>{
    const slot=getNextSlot(ev.times,nowSec);
    return{ev,slot};
  });

  const active=classified.filter(x=>x.slot&&x.slot.active);
  const upcoming=classified.filter(x=>x.slot&&!x.slot.active).sort((a,b)=>a.slot.secsUntilStart-b.slot.secsUntilStart);

  document.getElementById('timers-loading').style.display='none';
  document.getElementById('event-count').textContent=filtered.length+' EVENTS';
  document.getElementById('timer-live-tag').innerHTML='● LIVE';

  // ACTIVE
  const activeSection=document.getElementById('active-now-section');
  const activeGrid=document.getElementById('active-now-grid');
  if(active.length){
    activeSection.style.display='block';
    activeGrid.innerHTML=active.map(({ev,slot},i)=>`
      <div class="event-card-active">
        <div class="ev-badge ev-badge-active">⬡ ACTIVE NOW</div>
        <div class="ev-header">
          <img class="ev-icon" src="${ev.icon}" onerror="this.style.display='none'" alt=""/>
          <div>
            <div class="ev-name">${ev.name}</div>
            <div class="ev-map">// ${ev.map.toUpperCase()}</div>
          </div>
        </div>
        <div class="ev-time-row">
          <div class="ev-window">Window: <span>${slot.start} – ${slot.end} UTC</span></div>
          <div class="timer-display timer-active" id="ev-timer-a-${i}">ENDS ${fmtSeconds(slot.secsUntilEnd)}</div>
        </div>
        <div class="notify-toggle" id="ntog-a-${i}" onclick="toggleNotify(this,'a-${i}','${ev.name} on ${ev.map}')">
          <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;"></span>
          <span class="tog-txt">NOTIFY</span>
        </div>
      </div>`).join('');
  } else {
    activeSection.style.display='none';
  }

  // UPCOMING
  const upcomingSection=document.getElementById('upcoming-section');
  const upcomingGrid=document.getElementById('upcoming-grid');
  if(upcoming.length){
    upcomingSection.style.display='block';
    upcomingGrid.innerHTML=upcoming.map(({ev,slot},i)=>{
      const soon=slot.secsUntilStart<900;
      const cls=soon?'ev-badge-soon':'ev-badge-later';
      const label=soon?'▲ STARTING SOON':'◇ UPCOMING';
      const timerCls=soon?'timer-soon':'timer-normal';
      return`<div class="event-card-upcoming">
        <div class="ev-badge ${cls}">${label}</div>
        <div class="ev-header">
          <img class="ev-icon" src="${ev.icon}" onerror="this.style.display='none'" alt=""/>
          <div>
            <div class="ev-name">${ev.name}</div>
