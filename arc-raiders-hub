<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#030507;--bg2:#080c10;--bg3:#0d1319;--panel:#0a1018;
  --border:#1a2535;--gold:#FFD700;--red:#FF003C;--cyan:#00E5FF;
  --green:#00FF88;--muted:#3a5068;--text:#a8c4d8;--text2:#5a7a94;
  --white:#e0eef8;--font:'Share Tech Mono',monospace;--orb:'Orbitron',monospace;
}
body{background:var(--bg);color:var(--text);font-family:var(--font);overflow:hidden;height:100vh;display:flex;flex-direction:column;}
.scanline{position:fixed;top:0;left:0;right:0;bottom:0;pointer-events:none;z-index:9999;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,229,255,0.012) 2px,rgba(0,229,255,0.012) 4px);}

/* TOPBAR */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:44px;border-bottom:1px solid var(--border);background:var(--bg2);flex-shrink:0;}
.topbar-logo{font-family:var(--orb);font-size:13px;font-weight:900;letter-spacing:4px;color:var(--cyan);text-shadow:0 0 20px rgba(0,229,255,0.4);}
.topbar-logo span{color:var(--gold);}
.topbar-status{display:flex;gap:16px;font-size:10px;color:var(--text2);}
.status-dot{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:5px;}
.dot-live{background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse-dot 2s infinite;}
.dot-warn{background:var(--gold);}
.dot-dead{background:var(--red);}
@keyframes pulse-dot{0%,100%{opacity:1;}50%{opacity:.3;}}
.topbar-time{font-size:11px;color:var(--text2);letter-spacing:2px;}

/* LAYOUT */
.layout{display:flex;flex:1;overflow:hidden;}
.nav-rail{width:58px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:12px 0;gap:4px;flex-shrink:0;}
.nav-btn{width:42px;height:42px;border:1px solid transparent;background:transparent;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;gap:4px;transition:all .2s;color:var(--muted);}
.nav-btn:hover{border-color:var(--border);background:var(--bg3);color:var(--text);}
.nav-btn.active{border-color:var(--cyan);background:rgba(0,229,255,.06);color:var(--cyan);}
.nav-btn svg{width:18px;height:18px;fill:currentColor;}
.nav-btn .nav-label{font-size:7px;letter-spacing:1px;}
.nav-divider{width:30px;height:1px;background:var(--border);margin:6px 0;}
.main{flex:1;overflow:hidden;display:flex;flex-direction:column;}
.tab-content{flex:1;overflow-y:auto;padding:16px;display:none;}
.tab-content.active{display:block;}
.tab-content::-webkit-scrollbar{width:4px;}
.tab-content::-webkit-scrollbar-track{background:transparent;}
.tab-content::-webkit-scrollbar-thumb{background:var(--border);}

/* HEADERS */
.section-header{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.section-header h2{font-family:var(--orb);font-size:11px;font-weight:700;letter-spacing:4px;color:var(--white);}
.section-tag{font-size:9px;padding:2px 8px;border:1px solid;letter-spacing:2px;}
.tag-live{border-color:var(--green);color:var(--green);}
.tag-warn{border-color:var(--gold);color:var(--gold);}
.tag-count{border-color:var(--muted);color:var(--muted);}
.hline{flex:1;height:1px;background:var(--border);}

/* EVENT TIMERS TAB */
.utc-bar{background:var(--bg2);border:1px solid var(--border);padding:10px 16px;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;font-size:10px;color:var(--text2);}
.utc-clock{font-size:20px;font-weight:700;color:var(--cyan);letter-spacing:4px;font-family:var(--orb);}
.map-filter-bar{display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap;}
.map-pill{background:transparent;border:1px solid var(--border);color:var(--text2);font-family:var(--font);font-size:9px;letter-spacing:2px;padding:5px 12px;cursor:pointer;transition:all .2s;}
.map-pill.active{border-color:var(--cyan);color:var(--cyan);background:rgba(0,229,255,.06);}
.map-pill:hover:not(.active){border-color:var(--muted);color:var(--text);}

/* ACTIVE NOW SECTION */
.active-now-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;margin-bottom:20px;}
.event-card-active{background:var(--panel);border:1px solid var(--red);padding:14px;position:relative;overflow:hidden;}
.event-card-active::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--red);box-shadow:0 0 12px var(--red);animation:pulse-red 1s infinite;}
@keyframes pulse-red{0%,100%{opacity:1;}50%{opacity:.4;}}
.event-card-upcoming{background:var(--panel);border:1px solid var(--border);padding:14px;position:relative;overflow:hidden;transition:border-color .2s;}
.event-card-upcoming:hover{border-color:var(--muted);}
.event-card-upcoming::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--cyan);}
.ev-badge{font-size:8px;letter-spacing:3px;margin-bottom:6px;}
.ev-badge-active{color:var(--red);}
.ev-badge-soon{color:var(--gold);}
.ev-badge-later{color:var(--text2);}
.ev-header{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.ev-icon{width:32px;height:32px;object-fit:contain;flex-shrink:0;}
.ev-icon-placeholder{width:32px;height:32px;background:var(--bg3);border:1px solid var(--border);flex-shrink:0;}
.ev-name{font-family:var(--orb);font-size:12px;font-weight:700;color:var(--white);letter-spacing:1px;}
.ev-map{font-size:9px;color:var(--text2);letter-spacing:2px;margin-top:2px;}
.ev-time-row{display:flex;align-items:center;justify-content:space-between;margin-top:8px;}
.ev-window{font-size:10px;color:var(--text2);}
.ev-window span{color:var(--white);}
.timer-display{font-size:16px;letter-spacing:3px;font-weight:700;}
.timer-active{color:var(--red);animation:blink-t .9s step-end infinite;}
.timer-soon{color:var(--gold);}
.timer-normal{color:var(--cyan);}
@keyframes blink-t{50%{opacity:.3;}}
.notify-toggle{display:flex;align-items:center;gap:5px;cursor:pointer;font-size:8px;letter-spacing:2px;color:var(--muted);border:1px solid var(--border);padding:3px 8px;transition:all .2s;margin-top:6px;width:fit-content;}
.notify-toggle.on{color:var(--green);border-color:var(--green);}

/* UPCOMING TABLE */
.upcoming-section{margin-top:8px;}
.upcoming-label{font-size:9px;letter-spacing:3px;color:var(--text2);margin-bottom:8px;}
.upcoming-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:8px;}

/* ITEMS TAB */
.item-controls{display:flex;gap:8px;margin-bottom:14px;align-items:center;flex-wrap:wrap;}
.search-bar{flex:1;min-width:180px;background:var(--bg3);border:1px solid var(--border);color:var(--white);font-family:var(--font);font-size:11px;padding:8px 12px;outline:none;transition:border-color .2s;}
.search-bar:focus{border-color:var(--cyan);}
.filter-btn{background:transparent;border:1px solid var(--border);color:var(--text2);font-family:var(--font);font-size:9px;letter-spacing:2px;padding:8px 12px;cursor:pointer;transition:all .2s;}
.filter-btn.active{border-color:var(--cyan);color:var(--cyan);}
.filter-btn:hover:not(.active){border-color:var(--muted);}
.item-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;}
.item-card{background:var(--panel);border:1px solid var(--border);padding:10px 12px;display:flex;align-items:center;gap:10px;}
.item-img-wrap{width:36px;height:36px;flex-shrink:0;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;}
.item-img-wrap img{width:32px;height:32px;object-fit:contain;}
.item-img-placeholder{font-size:7px;color:var(--muted);}
.item-info{flex:1;min-width:0;}
.item-name{font-size:10px;color:var(--white);margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.item-rarity{font-size:8px;letter-spacing:2px;}
.item-category{font-size:8px;color:var(--text2);margin-top:2px;}
.rarity-legendary{color:var(--gold);}
.rarity-epic{color:#8b00ff;}
.rarity-rare{color:#0077cc;}
.rarity-uncommon{color:#00b050;}
.rarity-common{color:#888;}
.load-more-btn{width:100%;margin-top:12px;background:transparent;border:1px solid var(--border);color:var(--text2);font-family:var(--font);font-size:9px;letter-spacing:3px;padding:10px;cursor:pointer;transition:all .2s;}
.load-more-btn:hover{border-color:var(--cyan);color:var(--cyan);}

/* TRADE TAB */
.trade-layout{display:flex;gap:10px;}
.trade-feed{flex:1;}
.trade-sidebar{width:220px;flex-shrink:0;}
.create-btn{width:100%;background:transparent;border:1px solid var(--cyan);color:var(--cyan);font-family:var(--font);font-size:10px;letter-spacing:3px;padding:10px;cursor:pointer;transition:all .2s;margin-bottom:10px;}
.create-btn:hover{background:rgba(0,229,255,.08);}
.info-box{background:var(--panel);border:1px solid var(--border);padding:12px;margin-bottom:10px;}
.info-box h3{font-family:var(--orb);font-size:9px;letter-spacing:3px;color:var(--text2);margin-bottom:10px;}
.info-row{display:flex;justify-content:space-between;font-size:10px;margin-bottom:6px;}
.trade-card{background:var(--panel);border:1px solid var(--border);padding:12px;margin-bottom:8px;cursor:pointer;transition:border-color .2s;}
.trade-card:hover{border-color:var(--cyan);}
.trade-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.trader-info{display:flex;align-items:center;gap:8px;}
.trader-avatar{width:28px;height:28px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--cyan);}
.trader-name{font-size:11px;color:var(--white);}
.trader-rep{font-size:9px;color:var(--gold);}
.trade-time{font-size:9px;color:var(--text2);}
.trade-items{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.trade-item-chip{display:flex;align-items:center;gap:6px;background:var(--bg3);border:1px solid var(--border);padding:5px 10px;font-size:10px;}
.trade-dot{width:6px;height:6px;border-radius:50%;}
.trade-tag{font-size:8px;letter-spacing:2px;padding:2px 6px;border:1px solid var(--border);color:var(--text2);}
.empty-feed{text-align:center;padding:40px 20px;color:var(--muted);font-size:10px;letter-spacing:2px;line-height:2;}

/* MODALS */
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(3,5,7,.88);z-index:1000;display:flex;align-items:center;justify-content:center;}
.modal-box{background:var(--bg2);border:1px solid var(--cyan);width:440px;max-width:95vw;padding:24px;position:relative;}
.modal-close{position:absolute;top:12px;right:12px;background:transparent;border:1px solid var(--border);color:var(--text2);font-family:var(--font);width:24px;height:24px;cursor:pointer;font-size:12px;}
.modal-title{font-family:var(--orb);font-size:11px;letter-spacing:4px;color:var(--cyan);margin-bottom:16px;}
.modal-trader{display:flex;align-items:center;gap:12px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--border);}
.modal-avatar{width:44px;height:44px;border:1px solid var(--cyan);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:var(--cyan);}
.modal-name{font-size:14px;color:var(--white);font-family:var(--orb);}
.stars{color:var(--gold);font-size:14px;letter-spacing:2px;}
.modal-section{font-size:9px;letter-spacing:3px;color:var(--text2);margin-bottom:8px;}
.proof-placeholder{background:var(--bg3);border:1px dashed var(--border);height:80px;display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--muted);letter-spacing:2px;margin-bottom:16px;}
.modal-btn{width:100%;background:transparent;border:1px solid var(--green);color:var(--green);font-family:var(--font);font-size:10px;letter-spacing:4px;padding:12px;cursor:pointer;margin-bottom:6px;}
.modal-btn:hover{background:rgba(0,255,136,.08);}
.modal-btn-sec{border-color:var(--border);color:var(--text2);}

/* CREATE OVERLAY */
.create-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(3,5,7,.92);z-index:1000;display:flex;align-items:center;justify-content:center;}
.create-box{background:var(--bg2);border:1px solid var(--border);width:560px;max-width:95vw;padding:24px;}
.create-box h2{font-family:var(--orb);font-size:11px;letter-spacing:4px;color:var(--white);margin-bottom:20px;}
.create-cols{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
.create-col label{font-size:9px;letter-spacing:3px;color:var(--text2);display:block;margin-bottom:6px;}
.search-wrap{position:relative;}
.ac-input{width:100%;background:var(--bg3);border:1px solid var(--border);color:var(--white);font-family:var(--font);font-size:11px;padding:9px 10px;outline:none;transition:border-color .2s;}
.ac-input:focus{border-color:var(--cyan);}
.ac-list{position:absolute;top:100%;left:0;right:0;background:var(--bg2);border:1px solid var(--border);border-top:none;max-height:200px;overflow-y:auto;z-index:10;}
.ac-list::-webkit-scrollbar{width:3px;}
.ac-list::-webkit-scrollbar-thumb{background:var(--border);}
.ac-item{display:flex;align-items:center;gap:8px;padding:7px 10px;cursor:pointer;font-size:10px;}
.ac-item:hover{background:rgba(0,229,255,.06);}
.ac-thumb{width:22px;height:22px;object-fit:contain;}
.ac-name{flex:1;color:var(--white);}
.ac-rar{font-size:8px;letter-spacing:1px;}
.sel-chip{display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border);padding:5px 10px;margin-top:6px;font-size:10px;}
.sel-thumb{width:24px;height:24px;object-fit:contain;}
.create-actions{display:flex;gap:8px;justify-content:flex-end;}
.btn-cancel{background:transparent;border:1px solid var(--border);color:var(--text2);font-family:var(--font);font-size:9px;letter-spacing:2px;padding:8px 16px;cursor:pointer;}
.btn-post{background:transparent;border:1px solid var(--cyan);color:var(--cyan);font-family:var(--font);font-size:9px;letter-spacing:2px;padding:8px 16px;cursor:pointer;}
.btn-post:hover{background:rgba(0,229,255,.08);}

/* TOAST */
.toast-container{position:fixed;bottom:20px;right:20px;z-index:2000;display:flex;flex-direction:column;gap:8px;}
.toast{background:var(--bg2);border:1px solid var(--green);padding:10px 14px;font-size:10px;color:var(--green);letter-spacing:2px;animation:slideIn .3s ease;}
@keyframes slideIn{from{transform:translateX(100%);opacity:0;}to{transform:translateX(0);opacity:1;}}
.loading-msg{text-align:center;padding:30px;color:var(--muted);font-size:10px;letter-spacing:3px;}
.spinner{display:inline-block;width:10px;height:10px;border:1px solid var(--muted);border-top-color:var(--cyan);border-radius:50%;animation:spin .8s linear infinite;margin-right:8px;vertical-align:middle;}
@keyframes spin{to{transform:rotate(360deg);}}
</style>
</head>
