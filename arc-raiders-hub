function postTrade(){const off=selItems.offer?.name||document.getElementById('offer-input').value.trim();const req=selItems.req?.name||document.getElementById('req-input').value.trim();if(!off||!req){showToast('ERROR: Both fields required','var(--red)');return;}const initials=off.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();trades.unshift({trader:'YOU',avatar:initials||'ME',offering:off,offRarity:selItems.offer?.rarity||'',requesting:req,reqRarity:selItems.req?.rarity||'',time:'just now'});renderTrades();closeCreate();showToast('TRADE POSTED — '+off+' FOR '+req);}
